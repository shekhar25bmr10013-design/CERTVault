# CERTVault - Blockchain Certificate Verification System

# ============================================
# DEPENDENCIES
# ============================================

# Node.js dependencies (huge folder - 100MB+)
# Others can install by running: npm install
node_modules/

# Lock files (optional, usually not needed in GitHub)
package-lock.json
yarn.lock

# NPM debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# ENVIRONMENT VARIABLES
# ============================================

# Contains passwords, API keys, database credentials
# NEVER commit this file to GitHub
.env
.env.local
.env.production
.env.development
.env.*.local

# ============================================
# RUNTIME & LOGS
# ============================================

# Process IDs and runtime data
pids/
*.pid
*.seed
*.pid.lock

# Log files (auto-generated, no value)
logs/
*.log
*.log.*

# ============================================
# TESTING & COVERAGE
# ============================================

# Test coverage reports (generated by testing tools)
coverage/
.nyc_output/
*.lcov
*.lcov.info

# ============================================
# CACHE FILES
# ============================================

# ESLint cache
.eslintcache

# Various cache folders
.cache/
.parcel-cache/
.turbo/
.vite/

# ============================================
# BUILD OUTPUTS
# ============================================

# Compiled / built files (others can build themselves)
dist/
build/
.out/
.next/
.nuxt/
.gatsby/

# ============================================
# OPERATING SYSTEM FILES
# ============================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.directory-*

# ============================================
# IDE / EDITOR FILES
# ============================================

# VS Code
.vscode/
.history/
*.code-workspace

# IntelliJ / WebStorm / PyCharm
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.swp
*.swo
*~
*.sublime-*

# Eclipse
.project
.classpath
.settings/
.metadata/

# ============================================
# USER UPLOADED FILES
# ============================================

# Certificate files uploaded by users
# Keep these local only
uploads/
temp-uploads/
user-uploads/
uploads/*.pdf
uploads/*.jpg
uploads/*.png

# Temporary files
tmp/
temp/
*.tmp
*.temp

# ============================================
# BACKUP FILES
# ============================================

# Backup copies (not needed in version control)
*.bak
*.backup
*.old
*.orig
*.save

# ============================================
# SECURITY & KEYS
# ============================================

# Private keys and certificates
*.key
*.pem
*.cert
*.crt
*.p12
*.pfx
*.p8

# ============================================
# DATABASE FILES
# ============================================

# Local database files
*.sqlite
*.sqlite3
*.db
*.mdb
*.accdb
*.sql

# ============================================
# DOCKER
# ============================================

# Docker overrides and local configs
docker-compose.override.yml
.dockerignore

# ============================================
# DATA STORAGE
# ============================================

# Project data files (contains user certificates)
# Uncomment below if you want to keep data files local only
# backend/data/*.json
# !backend/data/.gitkeep

# ============================================
# MISCELLANEOUS
# ============================================

# macOS metadata
__MACOSX/

# Windows shortcut files
*.lnk

# Archive files (local backups)
*.zip
*.rar
*.7z
*.tar.gz
*.tgz

# Debug files
*.log
*.pid
*.seed

# ============================================
# PROJECT SPECIFIC
# ============================================

# CERTVault specific ignores
certificates/*.pdf
certificates/*.jpg
certificates/*.png
temp-qrcodes/
*.qrcode.png

# ============================================
# END OF .gitignore
# ============================================
